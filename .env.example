# MLS 2.0 Environment Configuration
# Copy this file to .env and fill in your values.
# The .env file is git-ignored for security.

# ==============================================================================
# 1. INFRASTRUCTURE
# ==============================================================================

DATABRICKS_HOST=https://your-workspace.cloud.databricks.com
DATABRICKS_TOKEN=your-databricks-personal-access-token
DATABRICKS_WAREHOUSE_ID=your-sql-warehouse-id
DATABRICKS_CATALOG=mls2

RESO_API_HOST=0.0.0.0
RESO_API_PORT=3900

# Main brokerage identity (ListOfficeKey for RESO exports)
LIST_OFFICE_KEY=SHARPSIR-HQ-001
LIST_OFFICE_NAME="Sharp Sothebys International Realty"

# RESO API URL for integration tests (set on remote deployments)
# RESO_API_URL=https://mls.sharpsir.group/reso

# ==============================================================================
# 2. DATA SOURCES
# RESO fields: OriginatingSystemOfficeKey, OriginatingSystemName, OriginatingSystemID
# Types: QOBRIX_API, DASH_API, DASH_FILE
# ==============================================================================

# --- Source 1: Cyprus (Qobrix API) ---
SRC_1_OFFICE_KEY=SHARPSIR-CY-001
SRC_1_SYSTEM_NAME="Cyprus Sothebys International Realty"
SRC_1_SYSTEM_ID=QOBRIX_CY
SRC_1_TYPE=QOBRIX_API
SRC_1_COUNTRY=CY
SRC_1_CURRENCY=EUR
SRC_1_API_USER=your-qobrix-api-user-uuid
SRC_1_API_KEY=your-qobrix-api-key
SRC_1_API_URL=https://your-instance.qobrix.com/api/v2

# --- Source 2: Hungary (DASH JSON File) ---
SRC_2_OFFICE_KEY=SHARPSIR-HU-001
SRC_2_SYSTEM_NAME="Hungary Sothebys International Realty"
SRC_2_SYSTEM_ID=DASH_HU
SRC_2_TYPE=DASH_FILE
SRC_2_COUNTRY=HU
SRC_2_DIR=/home/bitnami/mls_2_0/dash_hsir_source
SRC_2_FILE=HSIR_Listings_readable.json

# --- Source 3: Kazakhstan (DASH API) ---
SRC_3_OFFICE_KEY=SHARPSIR-KZ-001
SRC_3_SYSTEM_NAME="Kazakhstan Sothebys International Realty"
SRC_3_SYSTEM_ID=DASH_KZ_SANDBOX
SRC_3_TYPE=DASH_API
SRC_3_COUNTRY=KZ
SRC_3_DASH_OFFICE_GUID=your-dash-office-guid
SRC_3_DASH_API_KEY=your-dash-api-key
SRC_3_DASH_OKTA_CLIENT_ID=your-okta-client-id
SRC_3_DASH_OKTA_CLIENT_SECRET=your-okta-client-secret
SRC_3_DASH_OKTA_TOKEN_URL=https://realogy.oktapreview.com/oauth2/.../v1/token
SRC_3_DASH_OKTA_SCOPE=https://btt.realogyfg.com/dashapi
SRC_3_DASH_API_URL=https://preprod1.api.anywhere.re/dash

# ==============================================================================
# 3. OAUTH 2.0 CLIENTS (RESO Web API Access)
# ==============================================================================
# Generate secrets with: openssl rand -hex 32

OAUTH_JWT_SECRET=your-jwt-secret-here
OAUTH_TOKEN_EXPIRE_MINUTES=60

# Client 1: Cyprus access
OAUTH_CLIENT_1_ID=reso-client-your-id
OAUTH_CLIENT_1_SECRET=your-client-secret
OAUTH_CLIENT_1_OFFICES=SHARPSIR-CY-001

# Client 2: Hungary access
OAUTH_CLIENT_2_ID=reso-client-hu-001
OAUTH_CLIENT_2_SECRET=your-client-secret
OAUTH_CLIENT_2_OFFICES=SHARPSIR-HU-001

# Client 3: Kazakhstan access
OAUTH_CLIENT_3_ID=reso-client-kz-001
OAUTH_CLIENT_3_SECRET=your-client-secret
OAUTH_CLIENT_3_OFFICES=SHARPSIR-KZ-001

# Client 4: Multi-office admin (optional)
# OAUTH_CLIENT_4_ID=reso-client-admin
# OAUTH_CLIENT_4_SECRET=your-admin-secret
# OAUTH_CLIENT_4_OFFICES=SHARPSIR-CY-001,SHARPSIR-HU-001,SHARPSIR-KZ-001

# ==============================================================================
# 4. EMAIL NOTIFICATIONS (Resend)
# ==============================================================================

RESEND_API_KEY=re_your_resend_api_key
RESEND_EMAIL_FROM="MLS Pipeline <noreply@yourdomain.com>"
RESEND_EMAIL_TO=recipient@example.com

# ==============================================================================
# 5. CLONE SOURCE WORKSPACE (optional)
# ==============================================================================
# Only needed for scripts/clone_workspace.py
# Points to the Databricks workspace to clone bronze data FROM
# CLONE_SOURCE_HOST=https://dbc-XXXX.cloud.databricks.com
# CLONE_SOURCE_TOKEN=your-source-databricks-token
# CLONE_SOURCE_WAREHOUSE_ID=your-source-warehouse-id
# CLONE_SOURCE_CATALOG=mls2
