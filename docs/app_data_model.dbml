// App data model — we add tables step by step
//
// To view diagram: https://dbdiagram.io/ or VS Code DBML extension

Project app_data_model {
  database_type: 'PostgreSQL'
  Note: 'Qobrix bronze/silver → app model; RESO-aligned where applicable'
}

// Columns as returned by Qobrix API (e.g. GET /api/v2/contacts/related-with/{association}/{id}/)
// Source: docs/qobrix_openapi.yaml — components/schemas/Contact
Table qobrix_api_contacts {
  id uuid [pk, not null, note: 'Read-only, unique']
  ref int [not null, note: 'Contact Unique ID, unique']
  assigned_to uuid [ref: > qobrix_api_contacts.id, note: 'Assigned To → Users']
  birthdate date [note: 'format: date']
  city varchar(255)
  consent_token varchar(255) [note: 'Read-only']
  contact_id uuid [ref: > qobrix_api_contacts.id, note: 'Works For → Contacts']
  country varchar(2) [note: 'ISO 2-letter']
  created timestamp [note: 'Read-only, date-time']
  created_by uuid [ref: > qobrix_api_contacts.id, note: 'Read-only → Users']
  description varchar(2048)
  email varchar(255) [note: 'format: email']
  email_2 varchar(255) [note: 'format: email']
  email_consent boolean
  first_name varchar(255)
  group_id uuid [note: '→ Groups']
  is_company boolean [not null]
  last_name varchar(255)
  legacy_id varchar(255) [note: 'Unique']
  marketing_consent boolean
  modified timestamp [note: 'Read-only, date-time']
  modified_by uuid [ref: > qobrix_api_contacts.id, note: 'Read-only → Users']
  name varchar(255)
  nationality varchar(35) [note: 'Country of nationality']
  personal_data_cleared timestamp [note: 'Read-only']
  phone varchar(255) [note: 'format: phone']
  phone_2 varchar(255) [note: 'Mobile Phone']
  phone_3 varchar(255) [note: 'Other Phone']
  phone_consent boolean
  post_code varchar(255)
  postal_consent boolean
  preferred_contact_method varchar(255) [note: 'phone, email, sms, whatsapp, Viber']
  preferred_language varchar(6) [note: '→ Languages.code']
  registration_number varchar(255)
  role varchar(255) [note: 'Job Title']
  sms_consent boolean
  state varchar(255)
  street varchar(255)
  title varchar(35) [note: 'mr, mrs, ms, miss, dr, prof, ...']
  trashed timestamp [note: 'Soft-delete timestamp']
  vat_number varchar(255)
  website varchar(1024) [note: 'format: url']
  custom_contact_person_first_name varchar
  custom_contact_person_last_name varchar
  custom_mailchimp_subscriber_status varchar [note: 'subscribed, unsubscribed, cleaned, pending, transactional']
  custom_works_for uuid [ref: > qobrix_api_contacts.id, note: 'Primary Contact → Contacts']

  Note: 'Contact payload from Qobrix API (getContactsRelatedWith, GET /contacts, etc.)'
}

// Bronze: leads (opportunities) from Qobrix API — API payload only; no derived columns.
// Source: Qobrix API opportunity payload (e.g. GET /api/v2/opportunities or similar).
Table qobrix_api_opportunities {
  id uuid [pk, not null]
  ref int [note: 'Opportunity ref']
  contact_name uuid [ref: > qobrix_api_contacts.id, note: 'Lead contact']
  agent uuid [note: 'Assigned agent', ref: > qobrix_api_contacts.id]
  owner uuid [note: 'Owner', ref: > qobrix_api_contacts.id]
  campaign_id uuid [note: 'Campaign']
  created timestamp
  created_by uuid [ref: > qobrix_api_contacts.id]
  modified timestamp
  modified_by uuid [ref: > qobrix_api_contacts.id]
  enquiry_date date
  enquiry_type varchar(255)
  status varchar(255)
  last_status_change timestamp
  buy_rent varchar(50) [note: 'to_buy, to_rent']
  source varchar(255) [note: 'direct, campaign, etc.']
  direct_source varchar(255) [note: 'e.g. campaign']
  source_description text
  description text
  legacy_id varchar(255)
  website_url varchar(1024)
  virtual_contact_name varchar(255)
  area_of_interest text [note: 'Polygon/wkt string']
  post_codes text [note: 'JSON array']
  enquiry_subtypes text [note: 'JSON array']
  town_planning_zone varchar(255) [note: 'e.g. residential']
  construction_stage varchar(255) [note: 'e.g. offplans']
  sorting_expression varchar(255) [note: 'e.g. price_low']
  list_selling_price_from decimal
  list_selling_price_to decimal
  list_selling_price decimal
  list_rental_price_from decimal
  list_rental_price_to decimal
  list_letting_price decimal
  lowest_selling_price decimal
  lowest_letting_price decimal
  bedrooms_from int
  bedrooms_to int
  bathrooms_from int
  bathrooms_to int
  covered_area_from_amount decimal
  covered_area_to_amount decimal
  internal_area_from_amount decimal
  internal_area_to_amount decimal
  total_area_from_amount decimal
  total_area_to_amount decimal
  plot_area_from_amount decimal
  plot_area_to_amount decimal
  storage_from_amount decimal
  storage_to_amount decimal
  frontage_from_amount decimal
  frontage_to_amount decimal
  covered_parking int
  parking_from int
  parking_to int
  furnished varchar(255) [note: 'e.g. furnished']
  air_condition boolean
  common_swimming_pool boolean
  private_swimming_pool boolean
  concierge_reception boolean
  electricity boolean
  water boolean
  elevator boolean
  registered_road boolean
  title_deeds boolean
  new_build boolean
  pets_allowed boolean
  enclosed_office_room boolean
  server_room boolean
  business_transfer_or_sale boolean
  business_transfer_commercial_activity text [note: 'JSON array e.g. bed_and_breakfast']
  notify_matching_properties boolean
  notify_properties_price_drop boolean
  next_follow_up_date timestamp
  last_website_visit timestamp
  closed_lost_reason_id uuid
  closed_lost_details text
  trashed timestamp
  custom_attended_webinar boolean
  custom_do_not_contact boolean
  custom_enquiry_low_budget boolean
  custom_enquiry_stage_type varchar(255) [note: 'e.g. Agent']
  custom_facebook_lead_id varchar(255)
  custom_general_interest_type varchar(255) [note: 'e.g. Investment']
  custom_interest_type varchar(255) [note: 'e.g. Project']
  custom_internal_area_amount decimal
  custom_mql boolean
  custom_project uuid
  custom_property uuid
  custom_sql boolean
  custom_webinars text [note: 'JSON array e.g. Registered']

  Note: 'Bronze: leads/opportunities from Qobrix API (opportunity payload)'
}

// Bronze: raw opportunity/lead change events from Qobrix audit API.
// Mirrors the /opportunity changes endpoint: changed/original/meta as JSON blobs.
Table qobrix_api_opportunity_changes {
  id uuid [pk, not null]
  primary_key uuid [not null, ref: > qobrix_api_opportunities.id, note: 'Primary key of the changed record (opportunity UUID)']
  destination varchar(255) [note: 'Destination entity/table in Qobrix (e.g. opportunities)']
  destination_primary_key uuid [note: 'Destination primary key, usually same as primary_key for opportunities']
  source varchar(255) [note: 'Source system for the change']
  parent_source varchar(255)
  type varchar(100) [note: 'Event type from API (e.g. created, updated, deleted)']
  timestamp timestamp [not null]
  user_id uuid [ref: > qobrix_api_contacts.id, note: 'User who performed the action']
  impersonated_user_id uuid [note: 'If action was done via impersonation']
  changed text [note: 'JSON object with changed fields (field -> new value)']
  original text [note: 'JSON object with original values before change']
  meta text [note: 'JSON object with extra metadata from API']

  Note: 'Bronze: raw opportunity change events from Qobrix opportunity changes API'
}

// Bronze: agents from Qobrix API — API payload only; no derived columns.
// Represents external agents/agencies that may list or co-broker properties.
Table qobrix_api_agents {
  id uuid [pk, not null]
  ref int
  legacy_id varchar(255)
  name varchar(255)
  description text
  status varchar(255) [note: 'e.g. without_agency_agreement']
  agent_type varchar(50) [note: 'e.g. individual_agent']
  agency uuid [note: 'Related agency/company']
  owner uuid [ref: > qobrix_api_contacts.id]
  primary_contact uuid [ref: > qobrix_api_contacts.id]
  sub_agent_of uuid [ref: > qobrix_api_agents.id]
  agreement_date date
  commission_1 decimal
  commission_2 decimal
  commission_3 decimal
  created timestamp
  created_by uuid [ref: > qobrix_api_contacts.id]
  modified timestamp
  modified_by uuid [ref: > qobrix_api_contacts.id]
  trashed timestamp

  Note: 'Bronze: agents from Qobrix API (agent payload)'
}

// Bronze: projects from Qobrix API — API payload only; no derived columns.
// A project groups multiple properties (e.g. a development/building).
Table qobrix_api_projects {
  id uuid [pk, not null]
  ref int
  legacy_id varchar(255)
  name varchar(255)
  abbreviation varchar(255)
  reference_code varchar(255)
  type varchar(50) [note: 'e.g. project']
  housing_type varchar(255) [note: 'e.g. commercial, residential']
  availability_status varchar(255) [note: 'e.g. units_available']
  description text
  short_description text
  amenities_description text
  location_description text
  map_popup_description text
  developer_id uuid
  assigned_to uuid [ref: > qobrix_api_contacts.id, note: 'Assigned To → Users']
  location uuid
  coordinates varchar(255) [note: 'e.g. 12.1234,12.1234']
  country varchar(2)
  state varchar(255)
  city varchar(255)
  municipality varchar(255)
  post_code varchar(255)
  street varchar(255)
  street_2 varchar(255)
  completion_date date
  construction_stage varchar(255) [note: 'e.g. offplans']
  number_of_units int
  starting_price_from decimal
  price_to decimal
  project_listing_priority int
  website_status varchar(255) [note: 'e.g. published']
  website_url varchar(1024)
  website_listing_date timestamp
  video_link varchar(1024)
  video_links text [note: 'Raw field from API']
  virtual_tour_link varchar(1024)
  virtual_tour_links text [note: 'Raw field from API']
  last_media_update timestamp
  views text [note: 'JSON array']
  further_features text [note: 'JSON array']
  distance_from_airport_amount decimal
  distance_from_beach_amount decimal
  distance_from_centre_amount decimal
  distance_from_hospital_amount decimal
  distance_from_rail_station_amount decimal
  distance_from_school_amount decimal
  distance_from_shops_amount decimal
  distance_from_tube_station_amount decimal
  distance_from_university_amount decimal
  featured boolean
  featured_priority int
  custom_active boolean
  custom_business_centre boolean
  custom_concierge_services boolean
  custom_delivery_date date
  custom_gym boolean
  custom_heated_pool boolean
  custom_kids_play_area boolean
  custom_list_selling_price_amount decimal
  custom_reception boolean
  custom_resale boolean
  custom_restaurant_cafe boolean
  custom_security_service boolean
  custom_spa boolean
  custom_tennis_court boolean
  custom_valet_parking boolean
  created timestamp
  created_by uuid [ref: > qobrix_api_contacts.id]
  modified timestamp
  modified_by uuid [ref: > qobrix_api_contacts.id]
  trashed timestamp

  Note: 'Bronze: projects from Qobrix API (project payload); used to group properties'
}

// Bronze: project features from Qobrix API — API payload only; no derived columns.
// Defines feature codes/labels used by projects (e.g. further_features.gym, further_features.bbq_area).
Table qobrix_api_project_features {
  id uuid [pk, not null]
  code varchar(255) [not null, note: 'Internal code, e.g. gym, bbq_area']
  label varchar(255) [not null, note: 'Human label, e.g. Gym, BBQ Area']
  field varchar(255) [not null, note: 'Project field this feature belongs to, e.g. further_features']
  dist boolean [note: 'Whether feature is distributed/visible']
  created timestamp
  created_by uuid [ref: > qobrix_api_contacts.id]
  modified timestamp
  modified_by uuid [ref: > qobrix_api_contacts.id]
  trashed timestamp

  Note: 'Bronze: project feature dictionary from Qobrix API; used to decode JSON arrays on projects'
}

// Bronze: property subtypes from Qobrix API — API payload only; no derived columns.
// Defines subtype codes/labels per property_type (e.g. maisonette_house, entire_building_office).
Table qobrix_api_property_subtypes {
  id uuid [pk, not null]
  code varchar(255) [not null, note: 'Internal code, e.g. maisonette_house, shop']
  label varchar(255) [not null, note: 'Human label, e.g. Maisonette, Shop']
  property_type varchar(255) [not null, note: 'Parent property type code, e.g. house, office, land']
  created timestamp
  created_by uuid [ref: > qobrix_api_contacts.id]
  modified timestamp
  modified_by uuid [ref: > qobrix_api_contacts.id]
  trashed timestamp

  Note: 'Bronze: property subtype dictionary from Qobrix API; aligns with qobrix_api_properties.property_type/property_subtype codes'
}

// Bronze: property types from Qobrix API — API payload only; no derived columns.
// Defines top-level property type codes (e.g. house, apartment, land, office).
Table qobrix_api_property_types {
  id uuid [pk, not null]
  code varchar(255) [not null, note: 'Internal type code, e.g. house, apartment, land']
  name varchar(255) [not null, note: 'Human label, e.g. House, Apartment, Land']
  base_type varchar(255) [note: 'High-level bucket, e.g. residential, commercial, land, other']
  config text [note: 'Raw config JSON from API']
  display_order int
  created timestamp
  created_by uuid [ref: > qobrix_api_contacts.id]
  modified timestamp
  modified_by uuid [ref: > qobrix_api_contacts.id]
  trashed timestamp

  Note: 'Bronze: property type dictionary from Qobrix API; aligns with qobrix_api_properties.property_type codes'
}

// Bronze: property viewings from Qobrix API — API payload only; no derived columns.
// Represents feedback/assessment per (viewing, property) pair.
Table qobrix_api_property_viewings {
  id uuid [pk, not null]
  property_id uuid [not null, ref: > qobrix_api_properties.id]
  viewing_id uuid [not null, note: 'Qobrix viewing entity id (appointment)']
  display_order int
  further_feedback text
  exterior_appeal_assessment decimal
  interior_appeal_assessment decimal
  location_assessment decimal
  price_assessment decimal
  views_assessment decimal
  viewing_outcome decimal
  created timestamp
  created_by uuid [ref: > qobrix_api_contacts.id]
  modified timestamp
  modified_by uuid [ref: > qobrix_api_contacts.id]
  trashed timestamp

  Note: 'Bronze: property viewings/feedback from Qobrix API; one row per property-viewing assessment'
}

// Bronze: media categories from Qobrix API — API payload only; no derived columns.
// Defines how media is grouped and where it can be used (properties, projects, etc.).
Table qobrix_api_media_categories {
  id uuid [pk, not null]
  name varchar(255) [not null]
  label varchar(255) [not null]
  related_model varchar(255) [note: 'e.g. properties, projects']
  media_types text [note: 'JSON array of media types']
  mime_types text [note: 'JSON array of MIME types']
  dist boolean
  public boolean
  signature_required boolean
  watermark boolean
  created timestamp
  created_by uuid [ref: > qobrix_api_contacts.id]
  modified timestamp
  modified_by uuid [ref: > qobrix_api_contacts.id]
  trashed timestamp

  Note: 'Bronze: media category dictionary from Qobrix API'
}

// Bronze: media files from Qobrix API — API payload only; no derived columns.
// Underlying file metadata used by media records.
Table qobrix_api_media_files {
  id uuid [pk, not null]
  filename varchar(1024)
  original_filename varchar(1024)
  original_url varchar(2048)
  href varchar(2048) [note: 'Resolved URL for serving']
  thumbnails text [note: 'Raw thumbnails payload from API']
  mime_type varchar(255)
  filesize int
  filesystem varchar(255)
  created timestamp
  modified timestamp

  Note: 'Bronze: media file metadata from Qobrix API'
}

// Bronze: media records from Qobrix API — API payload only; no derived columns.
// Generic media link: one row per media item attached to a property, project, etc.
Table qobrix_api_media {
  id uuid [pk, not null]
  category_id uuid [ref: > qobrix_api_media_categories.id]
  related_model varchar(255) [note: 'Target model, e.g. properties, projects']
  related_id uuid [note: 'Target record id in related_model']
  media_type varchar(50) [note: 'e.g. upload, url']
  reference_id varchar(255)
  display_order int
  file_id uuid [ref: > qobrix_api_media_files.id]
  created timestamp
  modified timestamp

  Note: 'Bronze: media from Qobrix API; links files/categories to properties, projects, etc.'
}

// Bronze: properties from Qobrix API — API payload only; no derived columns.
// Source: Qobrix API property payload (e.g. GET /api/v2/properties or similar).
Table qobrix_api_properties {
  id uuid [pk, not null]
