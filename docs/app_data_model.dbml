  custom_webinars text

  Note: 'Silver: leads from bronze; strings normalized'
}

// Silver layer: projects — normalized subset from bronze; 1:1 per project.
// String fields normalized (trim, lowercase where applicable); URLs cleaned.
Table qobrix_silver_projects {
  id uuid [pk, not null, ref: - qobrix_api_projects.id]
  ref int
  legacy_id text
  name text [note: 'Normalized']
  abbreviation text
  reference_code text
  type text
  housing_type text
  availability_status text
  description text [note: 'Normalized']
  short_description text [note: 'Normalized']
  amenities_description text [note: 'Normalized']
  location_description text
  map_popup_description text
  developer_id uuid
  assigned_to uuid [ref: > qobrix_silver_contacts.id]
  location uuid
  coordinates text
  country text
  state text
  city text
  municipality text
  post_code text
  street text
  street_2 text
  completion_date date
  construction_stage text
  number_of_units int
  starting_price_from decimal
  price_to decimal
  project_listing_priority int
  website_status text
  website_url text [note: 'Normalized URL']
  website_listing_date timestamp
  video_link text
  video_links text
  virtual_tour_link text
  virtual_tour_links text
  last_media_update timestamp
  views text [note: 'JSON array']
  further_features text [note: 'JSON array']
  distance_from_airport_amount decimal
  distance_from_beach_amount decimal
  distance_from_centre_amount decimal
  distance_from_hospital_amount decimal
  distance_from_rail_station_amount decimal
  distance_from_school_amount decimal
  distance_from_shops_amount decimal
  distance_from_tube_station_amount decimal
  distance_from_university_amount decimal
  featured boolean
  featured_priority int
  custom_active boolean
  custom_business_centre boolean
  custom_concierge_services boolean
  custom_delivery_date date
  custom_gym boolean
  custom_heated_pool boolean
  custom_kids_play_area boolean
  custom_list_selling_price_amount decimal
  custom_reception boolean
  custom_resale boolean
  custom_restaurant_cafe boolean
  custom_security_service boolean
  custom_spa boolean
  custom_tennis_court boolean
  custom_valet_parking boolean
  created timestamp
  created_by uuid [ref: > qobrix_silver_contacts.id]
  modified timestamp
  modified_by uuid [ref: > qobrix_silver_contacts.id]
  trashed timestamp

  Note: 'Silver: projects from bronze; strings normalized; refs common_users'
}

// Silver layer: agents — normalized subset from bronze; 1:1 per agent.
// String fields normalized (trim, lowercase where applicable).
Table qobrix_silver_agents {
  id uuid [pk, not null, ref: > qobrix_api_agents.id]
  ref int
  legacy_id text
  name text [note: 'Normalized']
  description text [note: 'Normalized']
  status text [note: 'Normalized']
  agent_type text
  agency uuid
  owner uuid [ref: > qobrix_silver_contacts.id]
  primary_contact uuid [ref: > qobrix_silver_contacts.id]
  sub_agent_of uuid [ref: > qobrix_silver_agents.id]
  agreement_date date
  commission decimal
  created timestamp
  created_by uuid [ref: > qobrix_silver_contacts.id]
  modified timestamp
  modified_by uuid [ref: > qobrix_silver_contacts.id]
  trashed timestamp

  Note: 'Silver: agents from bronze; strings normalized; linked to silver contacts for owner/primary_contact'
}

// Silver layer: project features — normalized subset from bronze; 1:1 per feature.
// String fields normalized (trim, lowercase where applicable).
Table qobrix_silver_project_features {
  id uuid [pk, not null, ref: > qobrix_api_project_features.id]
  code text [not null]
  label text [not null]
  field text [not null]
  dist boolean
  created timestamp
  created_by uuid [ref: > common_users.id]
  modified timestamp
  modified_by uuid [ref: > common_users.id]
  trashed timestamp

  Note: 'Silver: project feature dictionary from bronze; strings normalized; refs common_users'
}

// Silver layer: property subtypes — normalized subset from bronze; 1:1 per subtype.
// String fields normalized (trim, lowercase where applicable).
Table qobrix_silver_property_subtypes {
  id uuid [pk, not null, ref: > qobrix_api_property_subtypes.id]
  code text [not null]
  label text [not null]
  property_type text [not null]
  created timestamp
  created_by uuid [ref: > common_users.id]
  modified timestamp
  modified_by uuid [ref: > common_users.id]
  trashed timestamp

  Note: 'Silver: property subtype dictionary from bronze; strings normalized; refs common_users'
}

// Silver layer: property types — normalized subset from bronze; 1:1 per type.
// String fields normalized (trim, lowercase where applicable).
Table qobrix_silver_property_types {
  id uuid [pk, not null, ref: > qobrix_api_property_types.id]
  code text [not null]
  name text [not null]
  base_type text
  config text
  display_order int
  created timestamp
  created_by uuid [ref: > common_users.id]
  modified timestamp
  modified_by uuid [ref: > common_users.id]
  trashed timestamp

  Note: 'Silver: property type dictionary from bronze; strings normalized; refs common_users'
}

// Silver layer: property viewings — normalized subset from bronze; 1:1 per property-viewing record.
// Numeric assessments kept as decimals; text normalized.
Table qobrix_silver_property_viewings {
  id uuid [pk, not null, ref: > qobrix_api_property_viewings.id]
  property_id uuid [not null, ref: > qobrix_silver_properties.id]
  viewing_id uuid [not null]
  display_order int
  further_feedback text [note: 'Normalized']
  exterior_appeal_assessment decimal
  interior_appeal_assessment decimal
  location_assessment decimal
  price_assessment decimal
  views_assessment decimal
  viewing_outcome decimal
  created timestamp
  created_by uuid [ref: > common_users.id]
  modified timestamp
  modified_by uuid [ref: > common_users.id]
  trashed timestamp

  Note: 'Silver: property viewing feedback from bronze; refs qobrix_silver_properties and common_users'
}

// Silver layer: media categories — normalized subset from bronze; 1:1 per category.
// String fields normalized; JSON arrays kept as text.
Table qobrix_silver_media_categories {
  id uuid [pk, not null, ref: > qobrix_api_media_categories.id]
  name text [not null]
  label text [not null]
  related_model text
  media_types text [note: 'JSON array']
  mime_types text [note: 'JSON array']
  dist boolean
  public boolean
  signature_required boolean
  watermark boolean
  created timestamp
  created_by uuid [ref: > common_users.id]
  modified timestamp
  modified_by uuid [ref: > common_users.id]
  trashed timestamp

  Note: 'Silver: media category dictionary from bronze; strings normalized; refs common_users'
}

// Silver layer: media files — normalized subset from bronze; 1:1 per file.
// URLs and filenames cleaned where applicable.
Table qobrix_silver_media_files {
  id uuid [pk, not null, ref: > qobrix_api_media_files.id]
  filename text
  original_filename text
  original_url text
  href text
  thumbnails text
  mime_type text
  filesize int
  filesystem text
  created timestamp
  modified timestamp

  Note: 'Silver: media file metadata from bronze; strings normalized'
}

// Silver layer: media — normalized subset from bronze; 1:1 per media record.
// Keeps generic related_model/related_id so it can point to properties, projects, etc.
Table qobrix_silver_media {
  id uuid [pk, not null, ref: > qobrix_api_media.id]
  category_id uuid [ref: > qobrix_silver_media_categories.id]
  related_model text [note: 'Normalized target model, e.g. properties, projects']
  related_id uuid [note: 'Target record id; resolve to silver property/project by ETL']
  media_type text
  reference_id text
  display_order int
  file_id uuid [ref: > qobrix_silver_media_files.id]
  created timestamp
  modified timestamp

  Note: 'Silver: media links from bronze; normalized strings and refs to silver media files/categories'
}

// Gold (CDL): leads/opportunities for apps — general lead record (who, when, status, source, CRM flags).
Table common_leads {
  id uuid [pk, not null, ref: > qobrix_silver_opportunities.id]
  ref int
  contact_profile_id uuid [not null, ref: > common_contact_profiles.id, note: 'Lead contact in CDL']
  agent_id uuid [ref: > common_users.id]
  owner_id uuid [ref: > common_users.id]
  campaign_id uuid
  created timestamp
  created_by uuid [ref: > common_users.id]
  modified timestamp
  modified_by uuid [ref: > common_users.id]
  enquiry_date date
  enquiry_type text
  status text
  last_status_change timestamp
  buy_rent text [note: 'to_buy, to_rent; use with enquiry_type to divide buying vs selling leads']
  source text
  direct_source text
  source_description text
  description text
  website_url text
  virtual_contact_name text
  notify_matching_properties boolean
  notify_properties_price_drop boolean
  next_follow_up_date timestamp
  last_website_visit timestamp
  closed_lost_reason_id uuid
  closed_lost_details text
  custom_attended_webinar boolean
  custom_do_not_contact boolean
  custom_enquiry_low_budget boolean
  custom_enquiry_stage_type text
  custom_facebook_lead_id text
  custom_general_interest_type text
  custom_interest_type text
  custom_mql boolean
  custom_project uuid
  custom_property uuid
  custom_sql boolean
  custom_webinars text

  Note: 'Gold: lead record — identity, contact, assignment, status, source, CRM flags; refs common_contact_profiles, common_users'
}

// Gold (CDL): lead enquiry profile — property requirements/preferences (budget, location, size, features).
Table common_lead_enquiry_profiles {
  lead_id uuid [pk, not null, ref: > common_leads.id]
  area_of_interest text
  post_codes text [note: 'JSON array']
  enquiry_subtypes text
  town_planning_zone text
  construction_stage text
  sorting_expression text
  list_selling_price_from decimal
  list_selling_price_to decimal
  list_selling_price decimal
  list_rental_price_from decimal
  list_rental_price_to decimal
  list_letting_price decimal
  lowest_selling_price decimal
  lowest_letting_price decimal
  bedrooms_from int
  bedrooms_to int
  bathrooms_from int
  bathrooms_to int
  covered_area_from_amount decimal
  covered_area_to_amount decimal
  internal_area_from_amount decimal
  internal_area_to_amount decimal
  total_area_from_amount decimal
  total_area_to_amount decimal
  plot_area_from_amount decimal
  plot_area_to_amount decimal
  storage_from_amount decimal
  storage_to_amount decimal
  frontage_from_amount decimal
  frontage_to_amount decimal
  covered_parking int
  parking_from int
  parking_to int
  furnished text
  air_condition boolean
  common_swimming_pool boolean
  private_swimming_pool boolean
  concierge_reception boolean
  electricity boolean
  water boolean
  elevator boolean
  registered_road boolean
  title_deeds boolean
  new_build boolean
  pets_allowed boolean
  enclosed_office_room boolean
  server_room boolean
  business_transfer_or_sale boolean
  business_transfer_commercial_activity text
  custom_internal_area_amount decimal

  Note: 'Gold: lead enquiry profile — property requirements (budget, location, size, features); one-to-one with common_leads'
}

// Gold — lead/opportunity change log (audit trail for leads).
// Built from qobrix_api_opportunity_changes and app-side events; one row per field change.
Table common_lead_changelog {
  id uuid [pk, not null]
  lead_id uuid [not null, ref: > common_leads.id, note: 'Lead/opportunity this change refers to']
  changed_at timestamp [not null, note: 'When the change happened']
  changed_by_user_id uuid [ref: > common_users.id, note: 'Who made the change; NULL for system/batch']
  event_type varchar(50) [note: 'e.g. created, updated, status_changed, closed_lost']
  field_name varchar(255) [note: 'Field that changed (e.g. status, list_selling_price_from); NULL for whole-record events']
  old_value text [note: 'Previous value (string/JSON)']
  new_value text [note: 'New value (string/JSON)']
  source_system varchar(100) [note: 'e.g. qobrix, mls2_api, mobile_app, batch_import']
  raw_event_id uuid [ref: - qobrix_api_opportunity_changes.id, note: 'Optional link back to raw Qobrix event']

  Note: 'Gold CDL: lead/opportunity change logs; append-only audit trail per lead'
}

// Silver layer: only columns from app contact model (tmp/contacts_data_model.md).
// String fields (phone, email, website, address, etc.) are normalized/cleaned in this layer.
// Normalization rules: tmp/silver_contact_normalization_rules.md (for ETL and AI agents).
Table qobrix_silver_contacts {
  id uuid [pk, not null, ref: - qobrix_api_contacts.id]
  ref int [not null]
  first_name text [note: 'Normalized']
  last_name text [note: 'Normalized']
  name text [note: 'Full display name / company; normalized']
  is_company boolean [not null]
  email text [note: 'Normalized (trim, lowercase, validated)']
  email_2 text [note: 'Normalized']
  phone text [note: 'Normalized (e.g. E.164, trim)']
  phone_2 text [note: 'Normalized']
  website text [note: 'Normalized URL']
  street text [note: 'Normalized']
  city text [note: 'Normalized']
  state text [note: 'Normalized']
  post_code text [note: 'Normalized']
  country text [note: 'Country code; normalized']
  role text [note: 'Job title; normalized']
  registration_number text [note: 'Normalized']
  vat_number text [note: 'Normalized']
  nationality text [note: 'Normalized']
  assigned_to uuid [ref: > qobrix_silver_contacts.id]
  description text [note: 'Notes; normalized']
  email_consent boolean [not null, default: true]
  sms_consent boolean [not null, default: true]
  phone_consent boolean [not null, default: true]
  postal_consent boolean [not null, default: true]
  marketing_consent boolean [not null, default: true]
  consent_token text
  personal_data_cleared timestamp
  created timestamp
  modified timestamp
  created_by uuid [ref: > qobrix_silver_contacts.id]
  modified_by uuid [ref: > qobrix_silver_contacts.id]
  custom_contact_person_first_name text [note: 'Normalized']
  custom_contact_person_last_name text [note: 'Normalized']
  custom_works_for uuid [ref: > qobrix_silver_contacts.id]
  custom_mailchimp_subscriber_status text [note: 'subscribed, unsubscribed, cleaned, pending, transactional']

  Note: 'Silver layer: subset of API contact columns; string fields normalized. Rules: tmp/silver_contact_normalization_rules.md'
}


// Common Data Layer: main user information (e.g. for assigned_to, created_by, modified_by).
// Source: docs/qobrix_openapi.yaml — components/schemas/User (subset).
Table common_users {
  id uuid [pk, not null]
  contact_id uuid [ref: - qobrix_silver_contacts.id, note: 'Linked contact (agent/person)']
  active boolean [not null, default: true]
  role varchar(255) [note: 'User role in system']
  username varchar(255) [note: 'Login / unique identifier']
  name text [note: 'Display name']

  Note: 'Common Data Layer: main user/agent info; used by contacts.assigned_to, created_by, modified_by'
}


// Common Data Layer: contact profile — canonical contact data (name, address, contact info, etc.).
// One row per contact; fed from qobrix_silver_contacts. Columns align with tmp/contacts_data_model.md.
Table common_contact_profiles {
  id uuid [pk, not null, ref: - common_users.id, note: 'One profile per silver contact']
  ref int [not null, note: 'ContactLoginId']
  first_name text [note: 'FirstName']
  last_name text [note: 'LastName']
  name text [note: 'FullName / company display name']
  is_company boolean [not null]
  email text [note: 'Email']
  email_2 text [note: 'Email2']
  phone text [note: 'HomePhone / DirectPhone']
  phone_2 text [note: 'MobilePhone']
  website text [note: 'Qobrix_website']
  street text [note: 'HomeAddress1']
  city text [note: 'HomeCity']
  state text [note: 'HomeStateOrProvince']
  post_code text [note: 'HomePostalCode']
  country text [note: 'HomeCountry']
  role text [note: 'JobTitle']
  registration_number text
  vat_number text
  nationality text
  assigned_to uuid [ref: <> common_users.id, note: 'OwnerMemberKey']
  description text [note: 'Notes']
  email_consent boolean [not null, default: true]
  sms_consent boolean [not null, default: true]
  phone_consent boolean [not null, default: true]
  postal_consent boolean [not null, default: true]
  marketing_consent boolean [not null, default: true]
  consent_token text
  personal_data_cleared timestamp
  created timestamp
  modified timestamp
  created_by uuid [ref: <> common_users.id]
  modified_by uuid [ref: <> common_users.id]
  custom_contact_person_first_name text
  custom_contact_person_last_name text
  custom_works_for uuid [ref: <> common_users.id, note: 'Primary contact / company']
  custom_mailchimp_subscriber_status text

  Note: 'Common Data Layer: contact profile (name, address, contact info); source: qobrix_silver_contacts'
}

// Change log for one profile: one row per change event; stores modified timestamps (and who/when).
// Append-only; aligns with ContactAuditLog idea in tmp/contacts_data_model.md.
Table common_contact_profile_changelog {
  id uuid [pk, not null, ref: - common_users.id]
  changed_at timestamp [not null, note: 'When the change happened']
  changed_by_user_id uuid [ref: <> common_users.id, note: 'Who made the change; NULL for system/batch']
  event_type varchar(50) [note: 'e.g. created, updated, deleted, restored']
  field_name varchar(255) [note: 'Field that changed (e.g. phone, role); NULL for whole-record events']
  old_value text [note: 'Previous value (string/JSON)']
  new_value text [note: 'New value (string/JSON)']
  source_system varchar(100) [note: 'e.g. qobrix, mls2_api, mobile_app, batch_import']

  Note: 'Change logs for one profile: modified timestamps and audit fields per event'
}

// Marketing/CRM segments (lists, tags) — distinct from profile.role (buyer/seller, etc.).
// Examples: Newsletter, VIP, Open House 2024, Campaign X. A contact can be in many segments.
Table common_contact_segments {
  id uuid [pk, not null]
  name varchar(255) [not null, note: 'e.g. Newsletter, VIP, Open House 2024']
  description text [note: 'Optional description of the segment']
  created_at timestamp [not null]

  Note: 'Segment definitions; role (buyer/seller) stays on common_contact_profiles.role'
}

// Which profiles belong to which segments (many-to-many).
Table common_contact_profile_segments {
  contact_profile_id uuid [pk, not null, ref: > common_contact_profiles.id]
  segment_id uuid [pk, not null, ref: > common_contact_segments.id]
  added_at timestamp [not null]

  Note: 'Junction: profile ↔ segment; composite PK (profile, segment)'
}