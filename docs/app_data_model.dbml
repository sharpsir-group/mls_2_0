}

// Bronze: raw property change events from Qobrix audit API.
// Mirrors the /property changes endpoint: changed/original/meta as JSON blobs.
Table qobrix_api_property_changes {
  id uuid [pk, not null]
  primary_key uuid [not null, ref: > qobrix_api_properties.id, note: 'Primary key of the changed record (property UUID)']
  destination varchar(255) [note: 'Destination entity/table in Qobrix (e.g. properties)']
  destination_primary_key uuid [note: 'Destination primary key, usually same as primary_key for properties']
  source varchar(255) [note: 'Source system for the change']
  parent_source varchar(255)
  type varchar(100) [note: 'Event type from API (e.g. created, updated, deleted)']
  timestamp timestamp [not null]
  user_id uuid [ref: > qobrix_api_contacts.id, note: 'User who performed the action']
  impersonated_user_id uuid [note: 'If action was done via impersonation']
  changed text [note: 'JSON object with changed fields (field -> new value)']
  original text [note: 'JSON object with original values before change']
  meta text [note: 'JSON object with extra metadata from API']

  Note: 'Bronze: raw property change events from Qobrix property changes API'
}

