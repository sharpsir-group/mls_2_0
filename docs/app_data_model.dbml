// Gold — property change log (audit trail for listings/properties).
// Built from qobrix_api_property_changes and app-side events; one row per field change.
Table common_property_changelog {
  id uuid [pk, not null]
  property_id uuid [not null, ref: > common_properties.id, note: 'Property/listing this change refers to']
  changed_at timestamp [not null, note: 'When the change happened']
  changed_by_user_id uuid [ref: > common_users.id, note: 'Who made the change; NULL for system/batch']
  event_type varchar(50) [note: 'e.g. created, updated, deleted, restored, price_changed']
  field_name varchar(255) [note: 'Field that changed (e.g. list_selling_price_amount, status); NULL for whole-record events']
  old_value text [note: 'Previous value (string/JSON)']
  new_value text [note: 'New value (string/JSON)']
  source_system varchar(100) [note: 'e.g. qobrix, mls2_api, mobile_app, batch_import']
  raw_event_id uuid [ref: - qobrix_api_property_changes.id, note: 'Optional link back to raw Qobrix event']

  Note: 'Gold CDL: property change logs; append-only audit trail per property'
}

// Gold — projects (developments/buildings that group multiple properties).
// Used to surface project-level information in apps and link properties to their parent project.
// This table is the project listing record (identity, assignment, summary, pricing, high-level marketing).
Table common_projects {
  id uuid [pk, not null, ref: - qobrix_silver_projects.id]
  ref int
  name text
  abbreviation text
  reference_code text
  type text
  housing_type text
  availability_status text
  description text
  short_description text
  amenities_description text
  developer_id uuid
  assigned_to uuid [ref: > common_users.id]
  number_of_units int
  starting_price_from decimal
  price_to decimal
  project_listing_priority int
  website_status text
  website_url text
  website_listing_date timestamp
  featured boolean
  featured_priority int
  custom_active boolean
  custom_list_selling_price_amount decimal
  custom_resale boolean
  created timestamp
  created_by uuid [ref: > common_users.id]
  modified timestamp
  modified_by uuid [ref: > common_users.id]

  Note: 'Gold CDL: projects/developments; used to group common_properties by project'
}

// Gold — agents (brokerages/individual agents in the system).
// This table represents agent entities and connects them to contact profiles and users.
Table common_agents {
  id uuid [pk, not null, ref: - qobrix_silver_agents.id]
  ref int
  name text
  description text
  status text
  agent_type text
  agency_id uuid [note: 'Related agency/company; may point to another common_agents row']
  owner_profile_id uuid [ref: > common_users.id, note: 'Owner contact profile']
  primary_contact_profile_id uuid [ref: > common_users.id, note: 'Primary contact for this agent/agency']
  sub_agent_of_id uuid [ref: > common_agents.id]
  agreement_date date
  commission decimal
  created timestamp
  created_by uuid [ref: > common_users.id]
  modified timestamp
  modified_by uuid [ref: > common_users.id]

  Note: 'Gold CDL: agents/agencies; link Qobrix agents to contact profiles and users'
}

// Gold — project features dictionary for apps.
// Provides friendly labels and grouping for project features used in UI/filters.
Table common_project_features {
  id uuid [pk, not null, ref: > qobrix_silver_project_features.id]
  code text [not null, note: 'Internal code, e.g. gym, bbq_area']
  label text [not null, note: 'Human label, e.g. Gym, BBQ Area']
  field text [not null, note: 'Project field/group, e.g. further_features']
  dist boolean

  Note: 'Gold CDL: project feature dictionary; used to decode project further_features and build filters'
}

// Gold — property subtypes dictionary for apps.
// Provides friendly labels and mapping between property_type and property_subtype codes.
Table common_property_subtypes {
  id uuid [pk, not null, ref: > qobrix_silver_property_subtypes.id]
  code text [not null, note: 'Internal subtype code, e.g. maisonette_house, shop']
  label text [not null, note: 'Human label, e.g. Maisonette, Shop']
  property_type text [not null, note: 'Parent type code, e.g. house, office, land']

  Note: 'Gold CDL: property subtype dictionary; used with common_properties.property_type/property_subtype'
}

// Gold — property types dictionary for apps.
// Provides friendly labels and high-level buckets for property types.
Table common_property_types {
  id uuid [pk, not null, ref: > qobrix_silver_property_types.id]
  code text [not null, note: 'Internal type code, e.g. house, apartment, land']
  name text [not null, note: 'Human label, e.g. House, Apartment, Land']
  base_type text [note: 'High-level bucket, e.g. residential, commercial, land, other']
  display_order int

  Note: 'Gold CDL: property type dictionary; used with common_properties.property_type'
}

// Gold — property viewings/feedback for apps.
// One row per property-viewing assessment; links to common_properties and users.
Table common_property_viewings {
  id uuid [pk, not null, ref: > qobrix_silver_property_viewings.id]
  property_id uuid [not null, ref: > common_properties.id]
  viewing_id uuid [not null, note: 'Underlying Qobrix viewing/appointment id']
  display_order int
  further_feedback text
  exterior_appeal_assessment decimal
  interior_appeal_assessment decimal
  location_assessment decimal
  price_assessment decimal
  views_assessment decimal
  viewing_outcome decimal
  created timestamp
  created_by uuid [ref: > common_users.id]
  modified timestamp
  modified_by uuid [ref: > common_users.id]

  Note: 'Gold CDL: property viewings feedback; enables analytics on how buyers rate properties'
}

// Gold — media categories for apps.
// Used to group media in UI (e.g. gallery, plans, brochures) and drive upload rules.
Table common_media_categories {
  id uuid [pk, not null, ref: > qobrix_silver_media_categories.id]
  name text [not null]
  label text [not null]
  related_model text [note: 'Target entity type, e.g. properties, projects']
  dist boolean
  public boolean
  signature_required boolean
  watermark boolean

  Note: 'Gold CDL: media category dictionary; used to group media for properties/projects'
}

// Gold — media files for apps.
// Canonical file-level info (URL, mime type) used by media links below.
Table common_media_files {
  id uuid [pk, not null, ref: > qobrix_silver_media_files.id]
  filename text
  original_filename text
  original_url text
  href text
  thumbnails text
  mime_type text
  filesize int
  filesystem text

  Note: 'Gold CDL: media files; used by common_media to render URLs and thumbnails'
}

// Gold — media links for apps.
// Generic media attachment: can point to a property, project, or other entity.
Table common_media {
  id uuid [pk, not null, ref: > qobrix_silver_media.id]
  entity_type text [not null, note: 'Target entity type, e.g. property, project']
  entity_id uuid [not null, note: 'Target entity id (e.g. common_properties.id, common_projects.id)']
  category_id uuid [ref: > common_media_categories.id]
  media_type text
  reference_id text
  display_order int
  file_id uuid [ref: > common_media_files.id]
  created timestamp
  created_by uuid [ref: > common_users.id]
  modified timestamp
  modified_by uuid [ref: > common_users.id]

  Note: 'Gold CDL: media; generic linking table between files and entities (properties, projects, etc.)'
}

